[Unit]
Description=Velarium VPN Telegram bot
After=network.target

[Service]
Type=simple
User=velarium
WorkingDirectory=/opt/velarium/final_stable_clean
EnvironmentFile=/opt/velarium/final_stable_clean/.env
ExecStart=/opt/velarium/final_stable_clean/.venv/bin/python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
