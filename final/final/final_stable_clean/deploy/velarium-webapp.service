[Unit]
Description=Velarium VPN web cabinet (FastAPI Mini App)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/velarium/final/final/final_stable_clean
EnvironmentFile=/root/velarium/final/final/final_stable_clean/.env
ExecStart=/root/velarium/final/final/final_stable_clean/.venv/bin/uvicorn webapp_main:app --host 127.0.0.1 --port 8183
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
