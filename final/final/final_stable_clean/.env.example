# Copy this file to .env and fill in real values.
# .env must never be committed — it's already covered by .gitignore.

BOT_TOKEN=
OWNER_ID=
SUPPORT_USERNAME=
TRIAL_CHANNEL_USERNAME=
MANUAL_PAYMENT_URL=
PAYMENT_INVOICE_PREFIX=AT

# Platego (automatic SBP payments). Leave empty to fall back to MANUAL_PAYMENT_URL.
PLATEGO_MERCHANT_ID=
PLATEGO_API_KEY=

APP_SECRET_KEY=
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=

# Remnawave
REMNAWAVE_BASE_URL=
REMNAWAVE_TOKEN=
REMNAWAVE_SUB_PUBLIC_URL=
REMNAWAVE_SQUAD_UUID=
REMNAWAVE_SQUAD_NAME=

# Web dashboard (Telegram Mini App)
BOT_USERNAME=
WEBAPP_PUBLIC_URL=https://app.velariumvpn.ru
WEBAPP_SESSION_TTL_SECONDS=3600
WEBAPP_INIT_DATA_MAX_AGE_SECONDS=86400

# E-mail checkout (SMTP): verification codes + access delivery for e-mail buyers.
# Any SMTP works. Recommended: a transactional provider (Mailjet / Brevo / Resend),
# NOT personal Gmail (daily limits + spam risk). Leave empty to run in dev mode
# (verification code is shown on the checkout page instead of e-mailed).
#   Mailjet: SMTP_HOST=in-v3.mailjet.com  SMTP_USER=<API Key>  SMTP_PASSWORD=<Secret Key>
#   Gmail:   SMTP_HOST=smtp.gmail.com     SMTP_USER=<you@gmail.com>  SMTP_PASSWORD=<App Password>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Velarium VPN
EMAIL_CODE_TTL_SECONDS=600
